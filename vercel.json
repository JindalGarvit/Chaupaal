{
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Service-Worker-Allowed", "value": "/" },
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/ai", "destination": "/api/anthropic" },
    { "source": "/profile/(.*)", "destination": "/index.html" },
    { "source": "/post/(.*)", "destination": "/index.html" },
    { "source": "/chat/(.*)", "destination": "/index.html" },
    { "source": "/u/(.*)", "destination": "/index.html" },
    { "source": "/p/(.*)", "destination": "/index.html" },
    { "source": "/c/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/refresh-category-cache.js": {
      "maxDuration": 300
    },
    "api/chaupaal-scheduler.js": {
      "maxDuration": 120
    }
  },
  "crons": [
    {
      "path": "/api/chaupaal-scheduler",
      "schedule": "0 15 * * *"
    }
  ]
}
