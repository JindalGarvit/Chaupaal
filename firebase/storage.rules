rules_version = '2';
// Deny-by-default. Media uploads go through Cloudinary (unsigned preset via /api/media-config).
// If Firebase Storage is used later, add path-scoped auth.uid ownership rules here.
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
