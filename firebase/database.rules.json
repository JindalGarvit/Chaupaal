{
  "rules": {
    ".read": false,
    ".write": false,
    "typing": {
      "$chatId": {
        ".read": "auth != null",
        "$uid": {
          ".write": "auth != null && auth.uid == $uid",
          ".validate": "newData.hasChildren(['at']) || !newData.exists()"
        }
      }
    }
  }
}
