{
  "rules": {
    ".read": false,
    ".write": false,
    "typing": {
      "$chatId": {
        ".read": "auth != null",
        "$uid": {
          ".write": "auth != null && auth.uid == $uid",
          ".validate": "newData.hasChildren(['at']) || !newData.exists()"
        }
      }
    },
    "mehfil": {
      "$chatId": {
        ".read": "auth != null",
        "participants": {
          "$uid": {
            ".write": "auth != null && auth.uid == $uid",
            ".validate": "newData.hasChildren(['at']) || !newData.exists()"
          }
        },
        "media": {
          ".write": "auth != null && root.child('mehfil').child($chatId).child('participants').child(auth.uid).exists()",
          ".validate": "newData.hasChildren(['by', 'at']) && newData.child('by').val() == auth.uid"
        },
        "reactions": {
          ".write": "auth != null && root.child('mehfil').child($chatId).child('participants').child(auth.uid).exists()",
          "$rid": {
            ".validate": "newData.hasChildren(['emoji', 'by', 'at']) && newData.child('by').val() == auth.uid"
          }
        }
      }
    }
  }
}
