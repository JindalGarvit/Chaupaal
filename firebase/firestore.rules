rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===================== HELPERS =====================
    function isAuth() { return request.auth != null; }
    function isOwner(uid) { return request.auth.uid == uid; }
    function isNewDoc() { return !resource.exists(); }
    function notDeleting() { return request.resource.data.keys().hasAny(resource.data.keys()); }

    // Friend is derived: requester follows target AND target follows requester.
    function isFriend(targetUid) {
      return isAuth() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)/following/$(targetUid)) &&
        exists(/databases/$(database)/documents/users/$(targetUid)/following/$(request.auth.uid));
    }

    // Check if requester follows target
    function isFollower(targetUid) {
      return isAuth() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)/following/$(targetUid));
    }

    // Check if user is shadowbanned severely
    function isShadowbanned(uid) {
      return exists(/databases/$(database)/documents/shadowbans/$(uid)) &&
        get(/databases/$(database)/documents/shadowbans/$(uid)).data.tier == 'severe';
    }

    function canReadPeepal(questionId) {
      return isAuth() &&
        exists(/databases/$(database)/documents/peepal/$(questionId)) &&
        (
          !('deleted' in get(/databases/$(database)/documents/peepal/$(questionId)).data) ||
          get(/databases/$(database)/documents/peepal/$(questionId)).data.deleted == false ||
          isOwner(get(/databases/$(database)/documents/peepal/$(questionId)).data.uid)
        );
    }

    function canReadDuniya(postId) {
      let post = get(/databases/$(database)/documents/duniya/$(postId)).data;
      return isAuth() &&
        exists(/databases/$(database)/documents/duniya/$(postId)) &&
        (!('deleted' in post) || post.deleted == false || isOwner(post.uid)) &&
        (
          post.audience == 'public' ||
          isOwner(post.uid) ||
          (post.audience == 'followers' && isFollower(post.uid)) ||
          (post.audience == 'friends' && isFriend(post.uid))
        );
    }

    function validDuniyaLikeMutation(postId) {
      let oldCount = 'likes' in resource.data ? resource.data.likes : 0;
      let likePath = /databases/$(database)/documents/duniya/$(postId)/likes/$(request.auth.uid);
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likeMutationUid']) &&
        request.resource.data.likeMutationUid == request.auth.uid &&
        request.resource.data.likes is int &&
        request.resource.data.likes >= 0 &&
        (
          (request.resource.data.likes == oldCount + 1 && !exists(likePath) && existsAfter(likePath)) ||
          (request.resource.data.likes == oldCount - 1 && exists(likePath) && !existsAfter(likePath))
        );
    }

    function validPeepalCommentMutation(questionId) {
      let oldCount = 'comments' in resource.data ? resource.data.comments : 0;
      let commentId = request.resource.data.commentMutationId;
      let commentPath = /databases/$(database)/documents/peepal/$(questionId)/comments/$(commentId);
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['comments', 'commentMutationId']) &&
        commentId is string &&
        request.resource.data.comments is int &&
        request.resource.data.comments >= 0 &&
        (
          (request.resource.data.comments == oldCount + 1 && !exists(commentPath) && existsAfter(commentPath)) ||
          (request.resource.data.comments == oldCount - 1 && exists(commentPath) && !existsAfter(commentPath))
        );
    }

    function validDuniyaShareMutation(postId) {
      let oldCount = 'shares' in resource.data ? resource.data.shares : 0;
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['shares', 'shareMutationUid']) &&
        request.resource.data.shareMutationUid == request.auth.uid &&
        request.resource.data.shares is int &&
        request.resource.data.shares == oldCount + 1;
    }

    function validDuniyaCommentMutation(postId) {
      let oldCount = 'comments' in resource.data ? resource.data.comments : 0;
      let commentId = request.resource.data.commentMutationId;
      let commentPath = /databases/$(database)/documents/duniya/$(postId)/comments/$(commentId);
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['comments', 'commentMutationId']) &&
        commentId is string &&
        request.resource.data.comments is int &&
        request.resource.data.comments >= 0 &&
        (
          (request.resource.data.comments == oldCount + 1 && !exists(commentPath) && existsAfter(commentPath)) ||
          (request.resource.data.comments == oldCount - 1 && exists(commentPath) && !existsAfter(commentPath))
        );
    }

    function validClientErrorCounterFields() {
      return request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 500
        && request.resource.data.feature is string
        && request.resource.data.feature.size() <= 80
        && request.resource.data.day is string
        && request.resource.data.day.size() == 10
        && request.resource.data.signature is string
        && request.resource.data.signature.size() <= 240
        && (!('uid' in request.resource.data))
        && (!('email' in request.resource.data))
        && (!('phone' in request.resource.data))
        && (!('chatId' in request.resource.data))
        && (!('text' in request.resource.data));
    }

    function validCommentCreate() {
      return request.resource.data.keys().hasOnly(['uid', 'user', 'text', 'parentId', 'createdAt', 'editedAt']) &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.user.uid == request.auth.uid &&
        request.resource.data.text is string &&
        request.resource.data.text.size() > 0 &&
        request.resource.data.text.size() <= 2000 &&
        (request.resource.data.parentId == null || request.resource.data.parentId is string);
    }

    // ===================== USERS =====================
    match /users/{userId} {
      // Private document — owner only (email/phone/DOB/prefs). Others use users_public.
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['relationshipCounts']);

      // Instagram-style multi-profile under one auth identity
      match /profiles/{profileId} {
        allow read: if isOwner(userId);
        allow create, update, delete: if isOwner(userId);
      }
      allow delete: if isOwner(userId);

      // Policy usage (anon posts, AI Discovery messaging).
      // Owner may READ; writes go through POST /api/media-config
      // { action: 'policy_consume' } (Admin SDK) so quotas cannot be reset
      // client-side. (Previously owner-writable — quota-bypass hole.)
      match /policyUsage/{featureId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }

      // Legacy friends index is retired. Friendship is reciprocal following.
      match /friends/{friendId} {
        allow read, write: if false;
      }
      // Close Friends is owner-private and server-mediated.
      match /close_friends/{friendId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }
      // Canonical directional edge mirrors. Authenticated profiles can inspect
      // follow lists/counts; only the Admin-backed relationship API writes.
      match /followers/{followerId} {
        allow read: if isAuth();
        allow write: if false;
      }
      match /following/{targetId} {
        allow read: if isAuth();
        allow write: if false;
      }
      // Explicit friend requests are private to sender/recipient.
      match /friendRequests/{requesterId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }
      match /sentFriendRequests/{targetId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }
      // Story Highlights (named circles) — NOT the same as post archive.
      // Stories expire/archive by default; highlights opt expired stories back onto the profile.
      match /story_highlights/{highlightId} {
        allow read: if isAuth();
        allow write: if false; // stories API (Admin) only
      }
      // Archive hub custom folders for Duniya/Peepal posts (separate from Highlights).
      match /archive_categories/{categoryId} {
        allow read, write: if isOwner(userId);
      }
      // Story delivery metadata is private. The story API fans out and revokes
      // inbox entries; clients can only read their own delivery inbox.
      match /storyInbox/{deliveryId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }
      match /storyDeliveryManifests/{storyId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }
      // Compose drafts (Phase 2) — owner only
      match /drafts/{draftId} {
        allow read, write: if isOwner(userId);
      }
      // Device sessions (Phase 3)
      match /sessions/{sessionId} {
        allow read, write: if isOwner(userId);
      }
      // Chaupaal proactive events — server-authored; client dismiss/engage only
      match /chaupaalEvents/{eventId} {
        allow read: if isOwner(userId);
        allow create: if false;
        allow update: if isOwner(userId)
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['dismissed', 'dismissedAt', 'engaged', 'engagedAt', 'fastDismiss']);
        allow delete: if false;
      }
      // Private recommendation inputs written by trusted server endpoints.
      match /recommendationSignals/{signalId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }
    }

    // ===================== USERS_PUBLIC (cross-user reads) =====================
    // Owner may sync public fields, but cannot clear server-set discovery bans.
    match /users_public/{userId} {
      allow read: if isAuth();
      allow create: if isOwner(userId)
        && !('hiddenFromDiscovery' in request.resource.data
             && request.resource.data.hiddenFromDiscovery == true)
        && !request.resource.data.keys().hasAny(['email', 'phone', 'phoneNumber', 'dob', 'dateOfBirth']);
      allow update: if isOwner(userId)
        && (
          !('hiddenFromDiscovery' in resource.data)
          || request.resource.data.hiddenFromDiscovery == resource.data.hiddenFromDiscovery
        )
        // PII must never land on the world-readable public doc
        && !request.resource.data.keys().hasAny(['email', 'phone', 'phoneNumber', 'dob', 'dateOfBirth']);
      allow delete: if isOwner(userId);
    }

    // ===================== USERNAMES =====================
    // Authenticated get only (uid mapping must not be world-readable).
    // Pre-auth availability checks go through POST /api/media-config { action: 'username_check' }.
    match /usernames/{username} {
      allow get: if isAuth();
      allow list: if false;
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuth() && resource.data.uid == request.auth.uid;
    }

    // Invite tokens keyed by token string — get by id only (no token harvest via chat list).
    match /groupInvites/{token} {
      allow get: if isAuth();
      allow list: if false;
      allow create: if isAuth()
        && request.resource.data.chatId is string
        && request.resource.data.chatId.size() > 0
        && request.resource.data.chatId.size() <= 128
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isAuth()
        && resource.data.chatId is string
        && get(/databases/$(database)/documents/chats/$(resource.data.chatId)).data.admins.hasAny([request.auth.uid]);
    }

    // ===================== AKHBAAR / DAILY SCORES =====================
    match /daily_scores/{date}/scores/{userId} {
      allow read: if isAuth();
      allow create, update: if isOwner(userId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.score is int
        && request.resource.data.score >= 0
        && request.resource.data.total is int
        && request.resource.data.total >= 1
        && request.resource.data.total <= 200
        && request.resource.data.score <= request.resource.data.total
        && (!('name' in request.resource.data) || (
             request.resource.data.name is string
             && request.resource.data.name.size() <= 80
           ));
      allow delete: if isOwner(userId);
    }

    // ===================== CATEGORY CACHE =====================
    // Written by Vercel Cron (Admin SDK) every ~6h; clients read only.
    match /category_cache/{catId} {
      allow read: if isAuth();
      allow write: if false;
    }

    // ===================== PEEPAL QUESTIONS =====================
    match /peepal/{questionId} {
      // Soft-deleted posts: author can still read (recovery bin); others cannot.
      allow read: if isAuth() && (
        !('deleted' in resource.data) ||
        resource.data.deleted == false ||
        isOwner(resource.data.uid)
      );
      // Create: authenticated, not shadowbanned, own uid, sane sizes,
      // counters must start at zero, denormalized user blob cannot be spoofed.
      allow create: if isAuth()
        && request.resource.data.uid == request.auth.uid
        && !isShadowbanned(request.auth.uid)
        && request.resource.data.question is string
        && request.resource.data.question.size() > 0
        && request.resource.data.question.size() <= 2000
        && (!('totalResponses' in request.resource.data) || request.resource.data.totalResponses == 0)
        && (!('comments' in request.resource.data) || request.resource.data.comments == 0)
        && (!('user' in request.resource.data) || (
             request.resource.data.user is map
             && (!('uid' in request.resource.data.user) || request.resource.data.user.uid == request.auth.uid)
           ));
      // Update: owner can edit / soft-delete; comment-count bumps validated.
      // totalResponses is Admin SDK only (peepal-reactions API) — the old
      // open hasOnly(['totalResponses']) clause let any user set any value.
      allow update: if isAuth() && (
        isOwner(resource.data.uid) ||
        validPeepalCommentMutation(questionId)
      );
      allow delete: if isOwner(resource.data.uid);

      match /likes/{userId} {
        // Legacy Peepal likes are disabled. Peepal now uses private reactions.
        allow read, write: if false;
      }

      match /reactions/{userId} {
        // A viewer may see only their own reaction. Server endpoints perform
        // writes so aggregate integrity cannot be bypassed by clients.
        allow read: if canReadPeepal(questionId) && isOwner(userId);
        allow write: if false;
      }

      match /comments/{commentId} {
        allow read: if canReadPeepal(questionId);
        allow create: if canReadPeepal(questionId) && validCommentCreate();
        allow update: if isAuth() &&
          resource.data.uid == request.auth.uid &&
          request.resource.data.uid == resource.data.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'editedAt', 'deleted']) &&
          request.resource.data.text is string &&
          request.resource.data.text.size() <= 2000 &&
          (!('deleted' in request.resource.data) || request.resource.data.deleted is bool) &&
          (
            request.resource.data.text.size() > 0 ||
            ('deleted' in request.resource.data && request.resource.data.deleted == true)
          );
        allow delete: if isAuth() && (
          resource.data.uid == request.auth.uid ||
          get(/databases/$(database)/documents/peepal/$(questionId)).data.uid == request.auth.uid
        );
      }
    }

    // Counts are physically separate from public Peepal documents. Only the
    // post author can read both raw counts; Admin SDK is the sole writer.
    match /peepalReactionSummaries/{questionId} {
      allow read: if isAuth() && resource.data.ownerUid == request.auth.uid;
      allow write: if false;
    }

    // ===================== PEEPAL RESPONSES =====================
    match /peepal/{questionId}/responses/{responseId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isOwner(resource.data.uid);
    }

    // ===================== DUNIYA POSTS =====================
    match /duniya/{postId} {
      // Public/followers/friends visibility, plus soft-delete: only owner sees deleted
      allow read: if isAuth() && (
        (!('deleted' in resource.data) || resource.data.deleted == false || isOwner(resource.data.uid))
      ) && (
        resource.data.audience == 'public' ||
        isOwner(resource.data.uid) ||
        (resource.data.audience == 'followers' && isFollower(resource.data.uid)) ||
        (resource.data.audience == 'friends' && isFriend(resource.data.uid))
      );
      allow create: if isAuth()
        && request.resource.data.uid == request.auth.uid
        && !isShadowbanned(request.auth.uid)
        && (!('caption' in request.resource.data) || (
             request.resource.data.caption is string
             && request.resource.data.caption.size() <= 4000
           ))
        && (!('likes' in request.resource.data) || request.resource.data.likes == 0)
        && (!('comments' in request.resource.data) || request.resource.data.comments == 0)
        && (!('shares' in request.resource.data) || request.resource.data.shares == 0)
        && (!('user' in request.resource.data) || (
             request.resource.data.user is map
             && (!('uid' in request.resource.data.user) || request.resource.data.user.uid == request.auth.uid)
           ));
      allow update: if isAuth() && (
        isOwner(resource.data.uid) ||
        validDuniyaShareMutation(postId) ||
        validDuniyaLikeMutation(postId) ||
        validDuniyaCommentMutation(postId)
      );
      allow delete: if isOwner(resource.data.uid);

      match /likes/{userId} {
        allow read: if canReadDuniya(postId) && isOwner(userId);
        allow create: if canReadDuniya(postId) &&
          isOwner(userId) &&
          request.resource.data.keys().hasOnly(['uid', 'createdAt']) &&
          request.resource.data.uid == request.auth.uid;
        allow update: if false;
        allow delete: if isOwner(userId);
      }

      match /comments/{commentId} {
        allow read: if canReadDuniya(postId);
        allow create: if canReadDuniya(postId) && validCommentCreate();
        allow update: if isAuth() &&
          resource.data.uid == request.auth.uid &&
          request.resource.data.uid == resource.data.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'editedAt', 'deleted']) &&
          request.resource.data.text is string &&
          request.resource.data.text.size() <= 2000 &&
          (!('deleted' in request.resource.data) || request.resource.data.deleted is bool) &&
          (
            request.resource.data.text.size() > 0 ||
            ('deleted' in request.resource.data && request.resource.data.deleted == true)
          );
        allow delete: if isAuth() && (
          resource.data.uid == request.auth.uid ||
          get(/databases/$(database)/documents/duniya/$(postId)).data.uid == request.auth.uid
        );
      }
    }

    // ===================== DUNIYA STORIES (24h, public/followers) =====================
    match /duniya_stories/{storyId} {
      // Server-mediated to keep expiry, archive and interactions consistent.
      allow read, write: if false;
      match /likes/{userId} {
        allow read, write: if false;
      }
      match /comments/{commentId} {
        allow read, write: if false;
      }
    }

    // ===================== BAITHAK STORIES (friends / close friends only) =====================
    match /baithak_stories/{storyId} {
      // No audience list is readable from the client. The story API checks
      // reciprocal friendship/Close Friends membership on every access.
      allow read, write: if false;
      match /likes/{userId} {
        allow read, write: if false;
      }
      match /comments/{commentId} {
        allow read, write: if false;
      }
    }

    // ===================== CHATS =====================
    function isChatParticipant() {
      return isAuth() &&
        resource.data.participants != null &&
        resource.data.participants.hasAny([request.auth.uid]);
    }
    function isChatAdmin() {
      return isAuth() &&
        resource.data.admins != null &&
        resource.data.admins.hasAny([request.auth.uid]);
    }
    // Non-member may only arrayUnion themselves (+ memberProfiles / updatedAt) when invite is enabled.
    function validInviteSelfJoin() {
      return isAuth()
        && resource.data.invite != null
        && resource.data.invite.enabled == true
        && resource.data.invite.token is string
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['participants', 'memberProfiles', 'updatedAt', 'memberCount'])
        && request.resource.data.participants.hasAll(resource.data.participants)
        && request.resource.data.participants.hasAny([request.auth.uid])
        && !(resource.data.participants.hasAny([request.auth.uid]));
    }
    // Audited client writers: group-info, chat-presence, founder DM, self/chaupaal ensure.
    function chatMetadataUpdateAllowed() {
      let keys = request.resource.data.diff(resource.data).affectedKeys();
      let allowed = keys.hasOnly([
    // Allowlisted chat metadata keys also include rating/match plumbing
        'typing', 'reads', 'updatedAt', 'preview', 'lastMessageAt', 'sharedFirstHello',
        'participants', 'memberProfiles', 'discoveryOrigin', 'peerProfileType', 'origin',
        'name', 'description', 'avatar', 'photoURL', 'admins', 'permissions', 'invite',
        'openedBy', 'createdBy', 'firstMessageAt', 'matchMeta',
        'isPublic', 'nameLower', 'memberCount', 'discoverableNoticeAck'
      ]);
      let adminOnly = keys.hasAny(['admins', 'permissions', 'invite', 'isPublic', 'discoverableNoticeAck']);
      let infoKeys = keys.hasAny(['name', 'description', 'avatar', 'photoURL', 'nameLower']);
      let canEditInfo = isChatAdmin() ||
        (resource.data.permissions != null && resource.data.permissions.editInfo == 'all');
      return isChatParticipant()
        && allowed
        && (!adminOnly || isChatAdmin())
        && (!infoKeys || canEditInfo);
    }
    match /chats/{chatId} {
      // Participants always; public groups readable for global search (Phase 3.2).
      allow get: if isChatParticipant()
        || (resource.data.type == 'group' && resource.data.isPublic == true);
      allow list: if isChatParticipant()
        || (resource.data.type == 'group' && resource.data.isPublic == true);
      allow create: if isAuth()
        && request.resource.data.participants.hasAny([request.auth.uid])
        && (
          !(request.resource.data.keys().hasAny(['type'])) ||
          (
            request.resource.data.type != 'chaupaal' &&
            request.resource.data.type != 'self'
          ) ||
          (request.resource.data.type == 'chaupaal' && chatId == 'chat_chaupaal_' + request.auth.uid) ||
          (request.resource.data.type == 'self' && chatId == 'chat_self_' + request.auth.uid)
        );
      allow update: if validInviteSelfJoin() || chatMetadataUpdateAllowed();

      match /joinRequests/{requestUid} {
        allow read: if isAuth() &&
          get(/databases/$(database)/documents/chats/$(chatId)).data.admins.hasAny([request.auth.uid]);
        allow create: if isAuth()
          && requestUid == request.auth.uid
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.status == 'pending';
        allow update: if isAuth() &&
          get(/databases/$(database)/documents/chats/$(chatId)).data.admins.hasAny([request.auth.uid]);
        allow delete: if isAuth() &&
          (requestUid == request.auth.uid ||
           get(/databases/$(database)/documents/chats/$(chatId)).data.admins.hasAny([request.auth.uid]));
      }

      // Messages: participant-scoped reads; clients may only author their own uid.
      // Chaupaal / server messages are written via Admin SDK (bypasses rules).
      // Optional `music` map and/or `attachment` map for rich bubbles (photo/file/location/challenge).
      // Location attachments may include lat, lng, mode, placeName, address, liveShareId, expiresAt, durationMs, label.
      match /messages/{messageId} {
        allow read: if isAuth() &&
          get(/databases/$(database)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid]);
        allow create: if isAuth()
          && request.resource.data.uid == request.auth.uid
          && get(/databases/$(database)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid])
          && !(request.resource.data.keys().hasAny(['serverOwned']) && request.resource.data.serverOwned == true)
          && (!('text' in request.resource.data) || (
               request.resource.data.text is string
               && request.resource.data.text.size() <= 8000
             ))
          && (
            !('music' in request.resource.data) ||
            (
              request.resource.data.music is map
              && request.resource.data.music.keys().hasAll(['title', 'artist'])
              && request.resource.data.music.title is string
              && request.resource.data.music.artist is string
              && request.resource.data.music.title.size() > 0
              && request.resource.data.music.title.size() <= 160
              && request.resource.data.music.artist.size() <= 160
            )
          )
          && (
            !('attachment' in request.resource.data) ||
            (
              request.resource.data.attachment is map
              && request.resource.data.attachment.type is string
              && request.resource.data.attachment.type.size() > 0
              && request.resource.data.attachment.type.size() <= 40
              && (
                request.resource.data.attachment.type != 'location'
                || (
                  request.resource.data.attachment.lat is number
                  && request.resource.data.attachment.lng is number
                  && request.resource.data.attachment.lat >= -90
                  && request.resource.data.attachment.lat <= 90
                  && request.resource.data.attachment.lng >= -180
                  && request.resource.data.attachment.lng <= 180
                )
              )
            )
          );
        allow update: if false;
        allow delete: if isOwner(resource.data.uid);
      }
    }

    // ===================== CHAUPAAL SERVER STATE / FEEDBACK =====================
    // Activity + cadence state — Admin SDK only (client mirrors via API)
    match /chaupaalUserState/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;
    }
    match /chaupaalFeedback/{docId} {
      allow read: if false;
      allow write: if false;
    }
    match /chaupaalFeedbackSummaries/{date} {
      allow read: if false;
      allow write: if false;
    }
    // Client runtime errors (music/nav/shell) — create-only; daily summary via Admin SDK
    match /clientErrorReports/{docId} {
      allow create: if isAuth()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 500
        && request.resource.data.feature is string
        && request.resource.data.feature.size() <= 80;
      allow read, update, delete: if false;
    }
    // Aggregated error counters (signature × day) — client increment/merge only; admin reads via API
    match /clientErrorCounters/{docId} {
      allow create: if isAuth()
        && validClientErrorCounterFields()
        && request.resource.data.count is int
        && request.resource.data.count >= 1
        && request.resource.data.count <= 500;
      // Counters only move up, in bounded steps — no resets / poisoning
      allow update: if isAuth()
        && validClientErrorCounterFields()
        && request.resource.data.count is int
        && resource.data.count is int
        && request.resource.data.count > resource.data.count
        && request.resource.data.count <= resource.data.count + 500;
      allow read, delete: if false;
    }
    match /chaupaalMeta/{docId} {
      allow read, write: if false;
    }

    // Peepal intent weight profiles + engagement — Admin SDK only
    match /intentWeightProfiles/{profileId} {
      allow read, write: if false;
    }
    match /matchEngagementEvents/{eventId} {
      allow read, write: if false;
    }

    // ===================== DAILY CHECK-INS (journal — private) =====================
    // Genuine access boundary: only the owning uid may read/write. Never expose via
    // list queries to other clients. Content analysis (if any) must stay server-side
    // and must never drive user-visible reactive copy (Section 7 / 4B).
    match /daily_checkins/{docId} {
      allow read: if isAuth() && resource.data.uid == request.auth.uid;
      allow update, delete: if isAuth() && resource.data.uid == request.auth.uid;
      allow create: if isAuth()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasAll(['uid', 'text']);
      allow list: if false;
    }

    // ===================== MATCHMAKING =====================
    match /matchmaking/{category}/waiting/{docId} {
      allow read: if isAuth();
      allow create: if isAuth()
        && request.resource.data.uid == request.auth.uid
        && !('claimedBy' in request.resource.data);
      // Claimer may set claimedBy once; cannot rewrite uid / other fields.
      allow update: if isAuth()
        && resource.data.uid != request.auth.uid
        && !('claimedBy' in resource.data)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.claimedBy == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['claimedBy', 'claimerName', 'claimedAt']);
      // Owner or successful claimer may delete (clears the room).
      allow delete: if isAuth() && (
        resource.data.uid == request.auth.uid
        || resource.data.claimedBy == request.auth.uid
      );
    }

    // ===================== FLAGS & BLOCKS =====================
    match /user_flags/{flagId} {
      allow read: if false; // admin only in production
      allow create: if isAuth() && request.resource.data.reporterUid == request.auth.uid;
    }

    match /blocks/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /shadowbans/{userId} {
      allow read: if false; // internal only — never exposed to client
      allow write: if false; // Admin SDK /api/relationships flag_user|block_signal
    }

    // Post-chat ratings — rater can create; no client reads (intent weights via Admin)
    match /chatRatings/{ratingId} {
      allow read: if false;
      allow create: if isAuth()
        && request.resource.data.raterUid == request.auth.uid
        && request.resource.data.peerUid is string
        && request.resource.data.score is int
        && request.resource.data.score >= 1
        && request.resource.data.score <= 10;
      allow update, delete: if false;
    }

    // ===================== NOTIFICATIONS =====================
    match /notifications/{userId}/items/{notifId} {
      allow read, write: if isOwner(userId);
    }

    // ===================== TAAZA KHABAR (breaking news) =====================
    match /taaza_khabar/{docId} {
      allow read: if isAuth();
      allow write: if false; // admin / Cloud Function only
    }

    // ===================== PREMIUM =====================
    match /premium/{userId} {
      allow read: if isOwner(userId);
      allow write: if false; // only Cloud Function (Razorpay webhook) can write
    }

    // ===================== UNIFIED PAYMENTS LEDGER =====================
    // Written via Admin SDK (server-lib/payments.js). Clients may read own rows.
    match /chaupaalTransactions/{txId} {
      allow read: if isAuth() && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    // Companion product feedback (separate from chat / chaupaalFeedback)
    match /companionProductFeedback/{docId} {
      allow create: if isAuth()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 2000;
      allow read: if false; // Garvit / Admin SDK review only
      allow update, delete: if false;
    }

    // ===================== DAILY_SETS (Akhbaar reel — server-authored) =====================
    // Client: fetchTodaysContent() reads only. Writes via Admin / Console.
    // Public read: boot runs before auth and falls back to samples if denied.
    match /daily_sets/{date}/questions/{qid} {
      allow read: if true;
      allow write: if false;
    }

    // ===================== BONUS_POOL (Akhbaar bonus — server-authored) =====================
    match /bonus_pool/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ===================== USER_STATUS (presence) =====================
    // Client: initActivityStatus writes own doc; getUserStatus reads others.
    match /user_status/{userId} {
      allow read: if isAuth();
      allow create, update: if isAuth() && isOwner(userId)
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isOwner(userId);
    }

    // ===================== STRANGER_COUNTS (rate-limit sync) =====================
    // Client: any authed user may merge-increment a target's daily count
    // (doc id = `${targetUid}_${YYYY-MM-DD}`; primary enforcement is still local).
    match /stranger_counts/{docId} {
      allow read: if isAuth();
      allow create: if isAuth()
        && request.resource.data.keys().hasAll(['uid','date','count'])
        && request.resource.data.uid is string
        && request.resource.data.date is string
        && request.resource.data.count is int
        && request.resource.data.count >= 1
        && request.resource.data.count <= 10
        && docId == request.resource.data.uid + '_' + request.resource.data.date;
      // Increase-only in small steps: blocks resetting a target's count to 0
      // and one-shot grief-locking at 1000. Sync is advisory (writes are
      // .catch-swallowed client-side); real enforcement stays local + server.
      allow update: if isAuth()
        && request.resource.data.keys().hasAll(['uid','date','count'])
        && request.resource.data.uid is string
        && request.resource.data.date is string
        && request.resource.data.count is int
        && resource.data.count is int
        && request.resource.data.count > resource.data.count
        && request.resource.data.count <= resource.data.count + 10
        && request.resource.data.count <= 1000
        && docId == request.resource.data.uid + '_' + request.resource.data.date;
      allow delete: if false;
    }

    // ===================== SEARCH_FEEDBACK (analytics write-only) =====================
    match /search_feedback/{docId} {
      allow read: if false;
      allow create: if isAuth()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasAll(['uid','query','score','label']);
      allow update, delete: if false;
    }

    // ===================== MATCH_OUTCOMES (analytics write-only) =====================
    match /match_outcomes/{docId} {
      allow read: if false;
      allow create: if isAuth()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasAll(['uid','matchUid','outcome']);
      allow update, delete: if false;
    }

    // ===================== DISCOVERY_REACTIONS (analytics write-only) =====================
    match /discovery_reactions/{docId} {
      allow read: if false;
      allow create: if isAuth()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasAll(['uid','targetUid','reaction']);
      allow update, delete: if false;
    }

    // ===================== LIVE LOCATION SHARES =====================
    // Share ids only appear in messages participants can already read.
    // Owner creates/updates/stops; any authenticated user may get-by-id.
    match /liveLocationShares/{shareId} {
      allow get: if isAuth();
      allow list: if false;
      allow create: if isAuth()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasAll(['uid', 'lat', 'lng', 'active']);
      allow update: if isAuth()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuth() && resource.data.uid == request.auth.uid;
    }

    // ===================== FEATURE FLAGS (Phase 4) =====================
    // Clients may read; writes are console/Admin only (no client write rule).
    match /feature_flags/{flagId} {
      allow read: if isAuth();
      allow write: if false;
    }

  }
}
