ANTHROPIC_API_KEY=
# Also accepted as Anthropic_API_key for legacy Vercel naming.
# Web search only when enableWebSearch:true (Categories path) — currently paused client+cron side.

# Master AI kill-switch — MUST be the string "true" to allow any live provider call.
# Default / unset = OFF (no spend). Client also requires Firestore feature_flags/ai_features.enabled.
AI_FEATURES_ENABLED=false
# Which provider implementation api/lib/ai.js uses (only "anthropic" fully implemented today).
AI_PROVIDER=anthropic
# Optional tier → model overrides:
# AI_MODEL_FAST=claude-haiku-4-5-20251001
# AI_MODEL_BALANCED=claude-sonnet-4-6

# Category cache cron is paused in code (CATEGORY_CRON_PAUSED) and removed from vercel.json.
# When re-enabling: AI_FEATURES_ENABLED=true, CATEGORY_CRON_PAUSED=false, CAT_LIVE_AI_PAUSED=false, restore cron schedule.
# Chaupaal scheduler: vercel.json cron → /api/chaupaal-scheduler (Bearer CRON_SECRET).
# Fixed Goodnight time for everyone: 8:30 PM IST = 15:00 UTC (`0 15 * * *`).
# Hobby plan is limited to one cron/day; Pro unlocks hourly for future per-user windows.
CRON_SECRET=
FIREBASE_SERVICE_ACCOUNT_JSON=

# Cloudinary (Phase 2.5 media) — free tier, unsigned upload preset (no API secret in client).
# Dashboard → Settings → Upload → Add upload preset → Signing mode: Unsigned
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=

# Upstash Redis (Phase 4 rate limiting) — free tier REST API
# Console → Redis → REST API → copy URL + token
# Gemini embeddings (Peepal personal matchmaking) — free tier text-embedding-004.
# Not gated by AI_FEATURES_ENABLED; only used on profile create/edit + match queries use cache.
GEMINI_API_KEY=
# GEMINI_EMBED_MODEL=text-embedding-004

